<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bank_import_wizard_form" model="ir.ui.view">
        <field name="name">bank.statement.import.wizard.form</field>
        <field name="model">bank.statement.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Bank Statement">
                <group>
                    <group>
                        <field name="journal_id"/>
                        <field name="file_format"/>
                    </group>
                    <group>
                        <field name="statement_file" filename="statement_filename" widget="binary"/>
                        <field name="statement_filename" invisible="1"/>
                    </group>
                </group>
                <div class="alert alert-info" role="alert">
                    <strong>Supported formats:</strong>
                    CSV (with header row), MT940/SWIFT, CAMT.053 (ISO 20022 XML).
                    Duplicate transactions (same unique ID) are automatically skipped.
                </div>
                <group invisible="not import_count">
                    <field name="import_count" readonly="1"/>
                    <field name="skip_count" readonly="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_bank_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Bank Statement</field>
        <field name="res_model">bank.statement.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
