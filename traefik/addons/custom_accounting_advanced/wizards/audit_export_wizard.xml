<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_audit_export_wizard_form" model="ir.ui.view">
        <field name="name">account.audit.export.wizard.form</field>
        <field name="model">account.audit.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Audit File">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="export_format"/>
                    <field name="include_drafts"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </group>
                <div class="alert alert-info" role="alert">
                    Exports all posted journal entry lines for the selected period.
                    Use CSV for spreadsheet analysis, XML for structured data interchange.
                </div>
                <footer>
                    <button name="action_export" string="Export" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
