<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_accrual_list" model="ir.ui.view">
        <field name="name">account.accrual.provision.list</field>
        <field name="model">account.accrual.provision</field>
        <field name="arch" type="xml">
            <list string="Accruals / Prepayments / Provisions"
                  decoration-success="state == 'posted'"
                  decoration-muted="state == 'reversed'"
                  decoration-warning="auto_reverse_date != False and state == 'posted'">
                <field name="name"/>
                <field name="entry_type"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="account_id"/>
                <field name="amount" string="Amount (€)"/>
                <field name="auto_reverse_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_accrual_form" model="ir.ui.view">
        <field name="name">account.accrual.provision.form</field>
        <field name="model">account.accrual.provision</field>
        <field name="arch" type="xml">
            <form string="Accrual / Prepayment / Provision">
                <header>
                    <button name="action_post" string="Post" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_reverse" string="Reverse" type="object"
                            class="btn-warning" invisible="state != 'posted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,reversed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="entry_type"/>
                            <field name="amount"/>
                            <field name="account_id"/>
                            <field name="journal_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="auto_reverse_date"/>
                            <field name="move_id" readonly="1"/>
                            <field name="reversal_move_id" readonly="1"
                                   invisible="state != 'reversed'"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_accrual_provision" model="ir.actions.act_window">
        <field name="name">Accruals / Prepayments / Provisions</field>
        <field name="res_model">account.accrual.provision</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
