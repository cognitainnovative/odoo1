<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bv_annual_accounts_list" model="ir.ui.view">
        <field name="name">bv.annual.accounts.list</field>
        <field name="model">bv.annual.accounts</field>
        <field name="arch" type="xml">
            <list string="BV Annual Accounts"
                  decoration-success="state == 'filed'"
                  decoration-primary="state == 'approved'"
                  decoration-warning="state == 'review'">
                <field name="name"/>
                <field name="fiscal_year"/>
                <field name="total_revenue" string="Revenue (€)"/>
                <field name="net_result" string="Net Result (€)"/>
                <field name="total_assets" string="Total Assets (€)"/>
                <field name="state" widget="badge"/>
                <field name="accountant_id"/>
            </list>
        </field>
    </record>

    <record id="view_bv_annual_accounts_form" model="ir.ui.view">
        <field name="name">bv.annual.accounts.form</field>
        <field name="model">bv.annual.accounts</field>
        <field name="arch" type="xml">
            <form string="BV Annual Accounts">
                <header>
                    <button name="action_pull_from_accounting" string="Pull from Accounting"
                            type="object" class="btn-secondary"
                            invisible="state == 'filed'"/>
                    <button name="action_submit_for_review" string="Submit for Review"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success" invisible="state != 'review'"
                            groups="account.group_account_manager"/>
                    <button name="action_file" string="Mark as Filed" type="object"
                            class="btn-secondary" invisible="state != 'approved'"/>
                    <button name="action_export_csv" string="Export CSV" type="object"
                            class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,review,approved,filed"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="state == 'filed'">
                        <strong>⚠️ Note:</strong> Actual filing with KvK requires the official
                        publication pathway. This module prepares the accounts package only.
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="fiscal_year"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="accountant_id"/>
                        </group>
                        <group>
                            <field name="accountant_review_date" readonly="1"/>
                            <field name="accountant_approved_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Profit &amp; Loss">
                        <group>
                            <field name="total_revenue"/>
                            <field name="total_expenses"/>
                            <field name="net_result" readonly="1"/>
                        </group>
                    </group>
                    <group string="Balance Sheet">
                        <group>
                            <field name="total_assets"/>
                            <field name="total_liabilities"/>
                            <field name="total_equity"/>
                        </group>
                    </group>
                    <group string="Retained Earnings">
                        <group>
                            <field name="retained_earnings_start"/>
                            <field name="dividends"/>
                            <field name="retained_earnings_end" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes to Financial Statements">
                            <field name="notes" nolabel="1"/>
                        </page>
                        <page string="Management Report">
                            <field name="management_report" nolabel="1"/>
                        </page>
                        <page string="Accountant Notes" groups="account.group_account_manager">
                            <field name="auditor_notes" nolabel="1"/>
                        </page>
                        <page string="Documents">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_bv_annual_accounts" model="ir.actions.act_window">
        <field name="name">BV Annual Accounts</field>
        <field name="res_model">bv.annual.accounts</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
