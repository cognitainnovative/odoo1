<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Finance: Overdue Receivables ── -->
    <record id="action_finance_overdue_receivables" model="ir.actions.act_window">
        <field name="name">Overdue Receivables</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type','=','out_invoice'),
            ('state','=','posted'),
            ('payment_state','not in',['paid','reversed']),
            ('invoice_date_due','&lt;',context_today().strftime('%Y-%m-%d'))
        ]</field>
        <field name="context">{'search_default_overdue': 1}</field>
    </record>

    <!-- ── Finance: Overdue Payables ── -->
    <record id="action_finance_overdue_payables" model="ir.actions.act_window">
        <field name="name">Overdue Payables</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('move_type','=','in_invoice'),
            ('state','=','posted'),
            ('payment_state','not in',['paid','reversed']),
            ('invoice_date_due','&lt;',context_today().strftime('%Y-%m-%d'))
        ]</field>
    </record>

    <!-- ── Finance: Draft Entries (unposted) ── -->
    <record id="action_finance_draft_entries" model="ir.actions.act_window">
        <field name="name">Draft Journal Entries</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','draft'),('move_type','=','entry')]</field>
    </record>

    <!-- ── Finance: Analytic lines (budget/cost tracking proxy in Community) ── -->
    <record id="action_finance_budget_variance" model="ir.actions.act_window">
        <field name="name">Analytic Lines (Cost Tracking)</field>
        <field name="res_model">account.analytic.line</field>
        <field name="view_mode">pivot,list,form</field>
        <field name="context">{'group_by': ['account_id', 'date:month']}</field>
    </record>

    <!-- ── Finance: Unreconciled move lines (accruals proxy) ── -->
    <record id="action_finance_active_accruals" model="ir.actions.act_window">
        <field name="name">Unreconciled Journal Items</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('reconciled','=',False),
            ('account_id.reconcile','=',True),
            ('move_id.state','=','posted')
        ]</field>
    </record>

    <!-- ── Finance: Period Comparison (pivot) ── -->
    <record id="action_finance_period_pivot" model="ir.actions.act_window">
        <field name="name">Period Comparison</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="domain">[('move_id.state','=','posted')]</field>
        <field name="context">{'group_by': ['account_id', 'date:month']}</field>
    </record>

    <!-- ── Menus under Finance > Dashboard ── -->
    <menuitem id="menu_finance_dashboard_root"
              name="Finance Dashboard"
              parent="account.menu_finance"
              sequence="1"
              groups="account.group_account_user"/>

    <menuitem id="menu_finance_overdue_receivables"
              name="Overdue Receivables"
              parent="menu_finance_dashboard_root"
              action="action_finance_overdue_receivables"
              sequence="10"/>

    <menuitem id="menu_finance_overdue_payables"
              name="Overdue Payables"
              parent="menu_finance_dashboard_root"
              action="action_finance_overdue_payables"
              sequence="20"/>

    <menuitem id="menu_finance_draft_entries"
              name="Draft Entries"
              parent="menu_finance_dashboard_root"
              action="action_finance_draft_entries"
              sequence="30"/>

    <menuitem id="menu_finance_budget_variance"
              name="Budget vs Actual"
              parent="menu_finance_dashboard_root"
              action="action_finance_budget_variance"
              sequence="40"/>

    <menuitem id="menu_finance_active_accruals"
              name="Accruals &amp; Provisions"
              parent="menu_finance_dashboard_root"
              action="action_finance_active_accruals"
              sequence="50"/>

    <menuitem id="menu_finance_period_pivot"
              name="Period Comparison"
              parent="menu_finance_dashboard_root"
              action="action_finance_period_pivot"
              sequence="60"/>

</odoo>
