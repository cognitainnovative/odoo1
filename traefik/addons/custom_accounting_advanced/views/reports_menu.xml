<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Period Comparison: move lines grouped by account and month -->
    <record id="action_period_comparison" model="ir.actions.act_window">
        <field name="name">Period Comparison</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list</field>
        <field name="domain">[('move_id.state', '=', 'posted')]</field>
        <field name="context">{"group_by": ["account_id", "date:month"]}</field>
    </record>

    <!-- Management Reports submenu -->
    <menuitem id="menu_mgmt_reports"
              name="Management Reports"
              parent="account.menu_finance_reports"
              sequence="70"
              groups="account.group_account_manager"/>

    <menuitem id="menu_period_comparison"
              name="Period Comparison"
              parent="menu_mgmt_reports"
              action="action_period_comparison"
              sequence="10"
              groups="account.group_account_manager"/>

    <menuitem id="menu_budget_vs_actual_report"
              name="Budget vs Actual"
              parent="menu_mgmt_reports"
              action="action_budget"
              sequence="20"
              groups="account.group_account_manager"/>

    <menuitem id="menu_annual_accounts_mgmt"
              name="BV Annual Accounts"
              parent="menu_mgmt_reports"
              action="action_bv_annual_accounts"
              sequence="30"
              groups="account.group_account_manager"/>

    <menuitem id="menu_accruals_mgmt_report"
              name="Accruals / Provisions"
              parent="menu_mgmt_reports"
              action="action_accrual_provision"
              sequence="40"
              groups="account.group_account_manager"/>

</odoo>
