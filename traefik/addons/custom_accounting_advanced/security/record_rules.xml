<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_fiscal_year_company" model="ir.rule">
        <field name="name">Fiscal Year: company scope</field>
        <field name="model_id" ref="model_account_fiscal_year_custom"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_fixed_asset_company" model="ir.rule">
        <field name="name">Fixed Asset: company scope</field>
        <field name="model_id" ref="model_account_fixed_asset"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_budget_company" model="ir.rule">
        <field name="name">Budget: company scope</field>
        <field name="model_id" ref="model_account_budget_platform"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_accrual_company" model="ir.rule">
        <field name="name">Accrual/Provision: company scope</field>
        <field name="model_id" ref="model_account_accrual_provision"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_bv_annual_accounts_company" model="ir.rule">
        <field name="name">BV Annual Accounts: company isolation</field>
        <field name="model_id" ref="model_bv_annual_accounts"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
