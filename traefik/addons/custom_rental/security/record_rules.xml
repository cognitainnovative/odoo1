<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_rental_order_company" model="ir.rule">
        <field name="name">Rental Order: company scope</field>
        <field name="model_id" ref="model_rental_order"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="rule_rental_product_company" model="ir.rule">
        <field name="name">Rental Product: company scope</field>
        <field name="model_id" ref="model_rental_product"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
