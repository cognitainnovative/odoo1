<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Module category ───────────────────────────────────────────────── -->

    <record id="category_platform" model="ir.module.category">
        <field name="name">Platform</field>
        <field name="description">
            Platform-level roles that complement Odoo built-in groups.
            Built-in roles (Finance Manager, HR Manager, etc.) are mapped
            to account.group_account_manager, hr.group_hr_manager, etc.
        </field>
        <field name="sequence">1</field>
    </record>

    <!-- ── Odoo built-in equivalents (documented only) ───────────────────── -->
    <!--
        Super admin         → base.group_system
        Sales manager       → sales_team.group_sale_manager
        Sales user          → sales_team.group_sale_salesman
        Finance manager     → account.group_account_manager
        Accountant          → account.group_account_user
        HR manager          → hr.group_hr_manager
        Employee            → hr.group_hr_user
        Inventory manager   → stock.group_stock_manager
        Portal customer     → base.group_portal
    -->

    <!-- ── Privileges (Odoo 19: category → privilege → group) ────────────── -->

    <record id="privilege_company_admin" model="res.groups.privilege">
        <field name="name">Company Admin</field>
        <field name="category_id" ref="category_platform"/>
        <field name="sequence">10</field>
    </record>

    <record id="privilege_ai_admin" model="res.groups.privilege">
        <field name="name">AI Admin</field>
        <field name="category_id" ref="category_platform"/>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_support_manager" model="res.groups.privilege">
        <field name="name">Support Manager</field>
        <field name="category_id" ref="category_platform"/>
        <field name="sequence">30</field>
    </record>

    <record id="privilege_support_agent" model="res.groups.privilege">
        <field name="name">Support Agent</field>
        <field name="category_id" ref="category_platform"/>
        <field name="sequence">40</field>
    </record>

    <record id="privilege_rental_manager" model="res.groups.privilege">
        <field name="name">Rental Manager</field>
        <field name="category_id" ref="category_platform"/>
        <field name="sequence">50</field>
    </record>

    <record id="privilege_social_manager" model="res.groups.privilege">
        <field name="name">Social Media Manager</field>
        <field name="category_id" ref="category_platform"/>
        <field name="sequence">60</field>
    </record>

    <record id="privilege_payroll_manager" model="res.groups.privilege">
        <field name="name">Payroll Manager</field>
        <field name="category_id" ref="category_platform"/>
        <field name="sequence">70</field>
    </record>

    <!-- ── Groups ─────────────────────────────────────────────────────────── -->

    <!-- Company Admin: manages company settings, users, billing. -->
    <record id="group_company_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="privilege_company_admin"/>
        <field name="comment">
            Can manage company settings, invite/deactivate users, configure integrations,
            view all records within their company. Does not have Odoo server admin access.
        </field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- AI Admin: configures AI providers, manages prompts, views audit logs. -->
    <record id="group_ai_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="privilege_ai_admin"/>
        <field name="comment">
            Configures AI providers and API keys, manages prompt templates,
            can view AI audit logs and usage dashboards. Required for all
            AI-related admin tasks.
        </field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Support Manager: manages helpdesk teams, SLAs, canned replies. -->
    <record id="group_support_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_support_manager"/>
        <field name="comment">
            Manages support teams, SLA policies, canned replies, escalation rules.
            Can view and manage all tickets and chat sessions in their company.
        </field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Support Agent: handles assigned tickets and live chat sessions. -->
    <record id="group_support_agent" model="res.groups">
        <field name="name">Agent</field>
        <field name="privilege_id" ref="privilege_support_agent"/>
        <field name="comment">
            Can view and handle tickets and chat sessions assigned to them or
            unassigned in their company. Cannot manage team configuration.
        </field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Rental Manager: manages rental catalog, pricing, orders. -->
    <record id="group_rental_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_rental_manager"/>
        <field name="comment">
            Manages rental products, discount tiers, rental orders,
            and inspection/damage verifications. Has full CRUD on rental models.
        </field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Social Media Manager: manages social accounts, campaigns, WhatsApp. -->
    <record id="group_social_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_social_manager"/>
        <field name="comment">
            Manages social media accounts, schedules posts, runs campaigns,
            configures WhatsApp providers. Can view all social inbox messages.
        </field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Payroll Manager: runs payroll cycles, manages payslips, exports. -->
    <record id="group_payroll_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_payroll_manager"/>
        <field name="comment">
            Can run payroll cycles, manage payslips, configure tax rules,
            export payroll data, and view payroll audit logs.
        </field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>
