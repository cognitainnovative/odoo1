<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Campaigns are scoped to the user's company -->
    <record id="rule_crm_campaign_company" model="ir.rule">
        <field name="name">CRM Campaign: company scope</field>
        <field name="model_id" ref="model_crm_campaign"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Leads and opportunities scoped to the user's company -->
    <record id="rule_crm_lead_company" model="ir.rule">
        <field name="name">CRM Lead/Opportunity: company scope</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
