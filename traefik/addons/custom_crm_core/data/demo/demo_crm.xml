<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="demo_crm_campaign_zomer" model="crm.campaign">
        <field name="name">Zomer Promotie 2025</field>
        <field name="channel">email</field>
        <field name="state">active</field>
        <field name="description">Zomerse promotiecampagne gericht op bestaande klanten en nieuwe leads.</field>
        <field name="budget">5000.0</field>
        <field name="target_leads">50</field>
    </record>

    <record id="demo_crm_lead_bouwbedrijf" model="crm.lead">
        <field name="name">Nieuw kantoorcomplex — De Vries Bouwgroep</field>
        <field name="type">opportunity</field>
        <field name="partner_name">De Vries Bouwgroep B.V.</field>
        <field name="email_from">inkoop@devriesbouw.nl</field>
        <field name="phone">+31 20 555 1234</field>
        <field name="expected_revenue">45000.0</field>
        <field name="probability">40</field>
        <field name="platform_campaign_id" ref="demo_crm_campaign_zomer"/>
        <field name="gdpr_consent">True</field>
    </record>

    <record id="demo_crm_lead_logistiek" model="crm.lead">
        <field name="name">Magazijninrichting — Van den Berg Logistiek</field>
        <field name="type">opportunity</field>
        <field name="partner_name">Van den Berg Logistiek B.V.</field>
        <field name="email_from">directie@vdblogistiek.nl</field>
        <field name="phone">+31 10 444 5678</field>
        <field name="expected_revenue">28500.0</field>
        <field name="probability">65</field>
        <field name="platform_campaign_id" ref="demo_crm_campaign_zomer"/>
        <field name="gdpr_consent">True</field>
    </record>
</odoo>
