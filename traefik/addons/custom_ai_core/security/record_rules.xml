<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Company isolation: users only see documents belonging to their companies -->
    <record id="rule_ai_document_company" model="ir.rule">
        <field name="name">AI Document: company isolation</field>
        <field name="model_id" ref="model_ai_document"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_ai_document_chunk_company" model="ir.rule">
        <field name="name">AI Document Chunk: company isolation</field>
        <field name="model_id" ref="model_ai_document_chunk"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Audit log: users can only read their own company's audit entries -->
    <record id="rule_ai_audit_log_company" model="ir.rule">
        <field name="name">AI Audit Log: company isolation</field>
        <field name="model_id" ref="model_ai_audit_log"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Feedback: users see only their own company's feedback records -->
    <record id="rule_ai_feedback_company" model="ir.rule">
        <field name="name">AI Feedback: company isolation</field>
        <field name="model_id" ref="model_ai_feedback"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Prompt evaluations: company isolation -->
    <record id="rule_ai_prompt_evaluation_company" model="ir.rule">
        <field name="name">AI Prompt Evaluation: company isolation</field>
        <field name="model_id" ref="model_ai_prompt_evaluation"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
