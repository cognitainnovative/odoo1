<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ai_audit_log_list" model="ir.ui.view">
        <field name="name">ai.audit.log.list</field>
        <field name="model">ai.audit.log</field>
        <field name="arch" type="xml">
            <list string="AI Audit Log" create="false" edit="false" delete="false"
                  decoration-danger="status == 'error'"
                  decoration-warning="was_redacted">
                <field name="create_date" string="Date"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="user_id"/>
                <field name="provider_code"/>
                <field name="model_used"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'success'"
                       decoration-danger="status == 'error'"/>
                <field name="was_redacted"/>
                <field name="input_tokens"/>
                <field name="output_tokens"/>
                <field name="latency_ms" string="ms"/>
                <field name="output_preview"/>
            </list>
        </field>
    </record>

    <record id="view_ai_audit_log_form" model="ir.ui.view">
        <field name="name">ai.audit.log.form</field>
        <field name="model">ai.audit.log</field>
        <field name="arch" type="xml">
            <form string="AI Audit Entry" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="Date"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="provider_id"/>
                            <field name="provider_code"/>
                            <field name="model_used"/>
                        </group>
                        <group>
                            <field name="status" widget="badge"/>
                            <field name="was_redacted"/>
                            <field name="input_tokens"/>
                            <field name="output_tokens"/>
                            <field name="latency_ms" string="Latency (ms)"/>
                        </group>
                    </group>
                    <group string="Content">
                        <field name="input_hash" string="Input Hash (SHA-256)"/>
                        <field name="output_preview" string="Output Preview"/>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Related Record" invisible="not res_model">
                        <field name="res_model"/>
                        <field name="res_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ai_audit_log_search" model="ir.ui.view">
        <field name="name">ai.audit.log.search</field>
        <field name="model">ai.audit.log</field>
        <field name="arch" type="xml">
            <search string="AI Audit Log">
                <field name="provider_code"/>
                <field name="user_id"/>
                <filter string="Success" name="success" domain="[('status','=','success')]"/>
                <filter string="Errors" name="errors" domain="[('status','=','error')]"/>
                <filter string="PII Redacted" name="redacted" domain="[('was_redacted','=',True)]"/>
                <group>
                    <filter string="Provider" name="by_provider" context="{'group_by': 'provider_code'}"/>
                    <filter string="User" name="by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Date" name="by_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ai_audit_log" model="ir.actions.act_window">
        <field name="name">AI Audit Log</field>
        <field name="res_model">ai.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ai_audit_log_search"/>
        <field name="context">{"create": False}</field>
    </record>

</odoo>
