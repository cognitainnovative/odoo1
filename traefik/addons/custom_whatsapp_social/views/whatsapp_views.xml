<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- WhatsApp Messages -->
    <record id="view_wa_message_list" model="ir.ui.view">
        <field name="name">whatsapp.message.list</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Messages"
                  decoration-primary="direction == 'inbound' and state == 'received'"
                  decoration-warning="ai_approval_state == 'pending'"
                  decoration-muted="state == 'sent'">
                <field name="create_date" string="Time"/>
                <field name="direction"/>
                <field name="from_number"/>
                <field name="body" string="Message"/>
                <field name="partner_id"/>
                <field name="state" widget="badge"/>
                <field name="ai_approval_state" optional="show"/>
                <field name="opt_in"/>
                <button name="action_ai_draft_reply" string="AI Reply" type="object"
                        icon="fa-magic" class="btn-sm"
                        invisible="direction != 'inbound' or ai_approval_state != 'none'"/>
                <button name="action_approve_and_send" string="Send" type="object"
                        icon="fa-send" class="btn-sm btn-primary"
                        invisible="ai_approval_state != 'approved'"/>
            </list>
        </field>
    </record>

    <record id="view_wa_message_form" model="ir.ui.view">
        <field name="name">whatsapp.message.form</field>
        <field name="model">whatsapp.message</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Message">
                <header>
                    <button name="action_ai_draft_reply" string="AI Draft Reply" type="object"
                            class="btn-secondary"
                            invisible="direction != 'inbound' or ai_approval_state != 'none'"/>
                    <button name="action_approve_draft" string="Approve Reply" type="object"
                            class="btn-success" invisible="ai_approval_state != 'pending'"/>
                    <button name="action_reject_draft" string="Reject" type="object"
                            class="btn-danger" invisible="ai_approval_state != 'pending'"/>
                    <button name="action_approve_and_send" string="Send" type="object"
                            class="btn-primary" invisible="ai_approval_state != 'approved'"/>
                    <button name="action_handoff" string="Transfer to Agent" type="object"
                            class="btn-secondary"
                            invisible="state in ('sent','delivered','read','failed','transferred')"/>
                    <button name="action_create_lead" string="Create Lead" type="object"
                            class="btn-secondary" invisible="lead_id"/>
                    <button name="action_create_ticket" string="Create Ticket" type="object"
                            class="btn-secondary" invisible="ticket_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="received,pending_approval,approved,transferred,sent"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert"
                         invisible="opt_in">
                        <strong>Opt-in not recorded.</strong>
                        Verify this contact has opted in to receive WhatsApp messages.
                    </div>
                    <group>
                        <group>
                            <field name="direction"/>
                            <field name="from_number"/>
                            <field name="to_number"/>
                            <field name="partner_id"/>
                            <field name="opt_in"/>
                        </group>
                        <group>
                            <field name="provider_id"/>
                            <field name="template_id"/>
                            <field name="lead_id"/>
                            <field name="ticket_id"/>
                            <field name="assigned_agent_id"/>
                        </group>
                    </group>
                    <group string="Message">
                        <field name="body" nolabel="1" widget="text" readonly="1"/>
                    </group>
                    <group string="AI Draft Reply" invisible="ai_approval_state == 'none'">
                        <field name="ai_approval_state" widget="statusbar"
                               statusbar_visible="none,pending,approved,sent" nolabel="1"/>
                        <field name="ai_draft" nolabel="1" widget="text"/>
                        <div class="alert alert-warning mt-1" role="alert">
                            ⚠️ AI replies are NEVER sent automatically. Human approval required.
                        </div>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_wa_message" model="ir.actions.act_window">
        <field name="name">WhatsApp Messages</field>
        <field name="res_model">whatsapp.message</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_wa_pending_approval" model="ir.actions.act_window">
        <field name="name">Pending WA Approval</field>
        <field name="res_model">whatsapp.message</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('ai_approval_state','=','pending')]</field>
    </record>

    <!-- Provider list -->
    <record id="view_wa_provider_list" model="ir.ui.view">
        <field name="name">whatsapp.provider.list</field>
        <field name="model">whatsapp.provider</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Providers" editable="bottom" decoration-muted="not is_active">
                <field name="name"/>
                <field name="provider"/>
                <field name="app_review_status"/>
                <field name="is_active"/>
                <field name="from_number"/>
            </list>
        </field>
    </record>

    <record id="action_wa_provider" model="ir.actions.act_window">
        <field name="name">WhatsApp Providers</field>
        <field name="res_model">whatsapp.provider</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Template list -->
    <record id="view_wa_template_list" model="ir.ui.view">
        <field name="name">whatsapp.template.list</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <list string="Templates" editable="bottom">
                <field name="name"/>
                <field name="template_name"/>
                <field name="language"/>
                <field name="category"/>
                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_wa_template" model="ir.actions.act_window">
        <field name="name">WA Templates</field>
        <field name="res_model">whatsapp.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
