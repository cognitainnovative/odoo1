<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_planning_resource_list" model="ir.ui.view">
        <field name="name">platform.planning.resource.list</field>
        <field name="model">platform.planning.resource</field>
        <field name="arch" type="xml">
            <list string="Resources"
                  decoration-muted="not active"
                  decoration-warning="availability_state == 'maintenance'"
                  decoration-success="availability_state == 'available'">
                <field name="name"/>
                <field name="resource_type"/>
                <field name="employee_id"/>
                <field name="availability_state" widget="badge"/>
                <field name="upcoming_job_count" string="Upcoming Jobs"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_planning_resource_form" model="ir.ui.view">
        <field name="name">platform.planning.resource.form</field>
        <field name="model">platform.planning.resource</field>
        <field name="arch" type="xml">
            <form string="Planning Resource">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-calendar"
                                name="action_view_jobs" type="object">
                            <field name="upcoming_job_count" widget="statinfo" string="Upcoming"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="resource_type"/>
                            <field name="employee_id"/>
                            <field name="active"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="availability_state"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_planning_resource" model="ir.actions.act_window">
        <field name="name">Resources</field>
        <field name="res_model">platform.planning.resource</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
