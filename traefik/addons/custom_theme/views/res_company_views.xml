<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_brand_form" model="ir.ui.view">
        <field name="name">res.company.brand.form.inherit</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Branding" name="platform_branding">
                    <group string="Identity">
                        <group>
                            <field name="brand_logo" widget="image"
                                   options="{'size': [120, 40]}" nolabel="1"/>
                        </group>
                        <group>
                            <field name="brand_favicon" widget="image"
                                   options="{'size': [32, 32]}" nolabel="1"/>
                        </group>
                    </group>
                    <group string="Brand Colors">
                        <group>
                            <field name="brand_primary_color" placeholder="#1E40AF"/>
                            <field name="brand_secondary_color" placeholder="#64748B"/>
                        </group>
                        <group>
                            <field name="brand_accent_color" placeholder="#0284C7"/>
                            <field name="brand_bg_color" placeholder="#F8FAFC"/>
                        </group>
                    </group>
                    <group string="Typography">
                        <field name="brand_font_family"/>
                    </group>
                    <group string="PDF">
                        <field name="brand_pdf_header_text" placeholder="Your tagline or slogan"/>
                    </group>
                    <group string="Email">
                        <field name="brand_email_header_html" nolabel="1"/>
                        <field name="brand_email_footer_html" nolabel="1"/>
                    </group>
                    <group string="Portal Footer">
                        <field name="brand_portal_footer" nolabel="1"/>
                    </group>
                    <group string="Custom CSS" groups="base.group_no_one">
                        <field name="brand_custom_css" nolabel="1" widget="text"
                               placeholder="/* Additional CSS overrides */"/>
                    </group>
                    <div class="alert alert-info mt-2" role="alert">
                        Colors are served at <code>/web/platform/brand.css</code>.
                        Hard-refresh (<kbd>Ctrl+Shift+R</kbd>) after saving to see changes.
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
