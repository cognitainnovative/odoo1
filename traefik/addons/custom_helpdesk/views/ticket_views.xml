<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Ticket List ═══ -->
    <record id="view_helpdesk_ticket_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.list</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list string="Tickets"
                  decoration-danger="sla_breached"
                  decoration-primary="priority == '2'"
                  decoration-warning="priority == '1'"
                  decoration-muted="stage_id.is_closed">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="category"/>
                <field name="priority" widget="priority"/>
                <field name="skill_id" optional="show"/>
                <field name="product_id" optional="hide"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <field name="sla_deadline"/>
                <field name="sla_breached" column_invisible="True"/>
                <field name="ai_approval_state" widget="badge" optional="show"/>
                <field name="stage_id"/>
                <button name="action_ai_classify" string="Classify" type="object"
                        icon="fa-magic" class="btn-sm"
                        invisible="ai_category"/>
            </list>
        </field>
    </record>

    <!-- ═══ Ticket Kanban ═══ -->
    <record id="view_helpdesk_ticket_kanban" model="ir.ui.view">
        <field name="name">helpdesk.ticket.kanban</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="priority"/>
                <field name="user_id"/>
                <field name="ai_approval_state"/>
                <field name="stage_id"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <strong><field name="name"/></strong>
                            <field name="priority" widget="priority"/>
                        </div>
                        <div class="text-muted small mt-1">
                            <field name="partner_id"/> · <field name="category"/>
                        </div>
                        <footer>
                            <field name="stage_id" widget="badge"/>
                            <span invisible="ai_approval_state == 'none'" class="ms-1">
                                <field name="ai_approval_state" widget="badge"/>
                            </span>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Ticket Form ═══ -->
    <record id="view_helpdesk_ticket_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form string="Helpdesk Ticket">
                <header>
                    <button name="action_ai_classify" string="AI Classify" type="object"
                            class="btn-secondary" icon="fa-magic"
                            invisible="ai_category"/>
                    <button name="action_ai_draft_reply" string="AI Draft Reply" type="object"
                            class="btn-secondary"
                            invisible="ai_approval_state not in ('none','rejected')"/>
                    <button name="action_approve_reply" string="Approve Reply" type="object"
                            class="btn-success"
                            invisible="ai_approval_state != 'pending'"/>
                    <button name="action_reject_reply" string="Reject" type="object"
                            class="btn-danger"
                            invisible="ai_approval_state != 'pending'"/>
                    <button name="action_send_reply" string="Send Reply" type="object"
                            class="btn-primary"
                            invisible="ai_approval_state != 'approved'"/>
                    <button name="action_accept_ai_assignee" string="Accept AI Assignee" type="object"
                            class="btn-info"
                            invisible="not ai_suggested_user_id or user_id"/>
                    <button name="action_follow_up" string="Follow-up" type="object"
                            class="btn-secondary"
                            invisible="stage_id.is_closed"/>
                    <button name="action_knowledge_suggest" string="Knowledge" type="object"
                            class="btn-secondary"/>
                    <button name="action_close" string="Close" type="object"
                            class="btn-secondary"
                            invisible="stage_id.is_closed"/>
                    <field name="stage_id" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="alert alert-danger" role="alert"
                         invisible="not sla_breached">
                        <strong>⚠ SLA Breached!</strong> This ticket is past its SLA deadline.
                    </div>
                    <div class="alert alert-warning" role="alert"
                         invisible="not has_legal_risk">
                        <strong>⚠ Legal Risk Detected.</strong> Please review before replying.
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="category"/>
                            <field name="source"/>
                            <field name="language_code"/>
                        </group>
                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="user_id"/>
                            <field name="team_id"/>
                            <field name="skill_id"/>
                            <field name="product_id"/>
                            <field name="sla_id"/>
                            <field name="sla_deadline" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Linked Records">
                        <group>
                            <field name="lead_id"/>
                            <field name="sale_order_id"/>
                        </group>
                        <group>
                            <field name="invoice_id"/>
                        </group>
                    </group>
                    <group string="AI Analysis" invisible="not ai_summary">
                        <group>
                            <field name="ai_category" readonly="1"/>
                            <field name="ai_priority" readonly="1"/>
                            <field name="ai_sentiment" readonly="1"/>
                        </group>
                        <group>
                            <field name="is_complaint" readonly="1"/>
                            <field name="has_legal_risk" readonly="1"/>
                            <field name="has_missing_info" readonly="1"/>
                        </group>
                        <field name="ai_summary" nolabel="1" readonly="1" widget="text"/>
                        <group invisible="not ai_suggested_user_id">
                            <field name="ai_suggested_user_id" readonly="1"
                                   string="AI-Suggested Assignee"/>
                        </group>
                    </group>
                    <group string="AI Draft Reply"
                           invisible="ai_approval_state == 'none'">
                        <field name="ai_approval_state" widget="statusbar"
                               statusbar_visible="pending,approved,sent" nolabel="1"/>
                        <field name="ai_draft_reply" nolabel="1" readonly="1" widget="text"/>
                        <field name="ai_final_reply" nolabel="1" widget="text"
                               string="Final Reply (edit before approving)"/>
                        <field name="ai_edit_reason" widget="text"
                               placeholder="Reason for edit (required if changed — stored for AI improvement)"/>
                        <div class="alert alert-info" role="alert">
                            ⚠️ AI replies are NEVER sent automatically. Human approval required.
                        </div>
                    </group>
                    <group string="Internal Notes">
                        <field name="internal_note" nolabel="1" widget="text"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ Ticket Graph — Tickets by Stage ═══ -->
    <record id="view_helpdesk_ticket_graph" model="ir.ui.view">
        <field name="name">helpdesk.ticket.graph</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <graph string="Tickets by Stage" type="bar">
                <field name="stage_id" type="row"/>
                <field name="priority" type="col"/>
            </graph>
        </field>
    </record>

    <!-- ═══ Ticket Pivot ═══ -->
    <record id="view_helpdesk_ticket_pivot" model="ir.ui.view">
        <field name="name">helpdesk.ticket.pivot</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Ticket Analysis">
                <field name="team_id" type="row"/>
                <field name="stage_id" type="col"/>
                <field name="priority" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_helpdesk_ticket_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search string="Tickets">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="skill_id"/>
                <filter string="Open" name="open" domain="[('stage_id.is_closed','=',False)]"/>
                <filter string="SLA Breached" name="breached" domain="[('sla_deadline','&lt;',datetime.datetime.now()),('stage_id.is_closed','=',False)]"/>
                <filter string="Pending AI Approval" name="pending_ai" domain="[('ai_approval_state','=','pending')]"/>
                <filter string="My Tickets" name="mine" domain="[('user_id','=',uid)]"/>
                <group>
                    <filter string="Stage" name="by_stage" context="{'group_by': 'stage_id'}"/>
                    <filter string="Category" name="by_category" context="{'group_by': 'category'}"/>
                    <filter string="Priority" name="by_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Skill" name="by_skill" context="{'group_by': 'skill_id'}"/>
                    <filter string="Product" name="by_product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_helpdesk_ticket" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,kanban,graph,pivot,form</field>
        <field name="search_view_id" ref="view_helpdesk_ticket_search"/>
        <field name="context">{"search_default_open": 1}</field>
    </record>

    <record id="action_helpdesk_pending_approval" model="ir.actions.act_window">
        <field name="name">Pending AI Reply Approval</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('ai_approval_state','=','pending')]</field>
    </record>

</odoo>
