<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Quick-access actions for leave management -->
    <record id="action_leave_pending_approval" model="ir.actions.act_window">
        <field name="name">Leaves Awaiting Approval</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'confirm')]</field>
    </record>

    <record id="action_leave_balance_summary" model="ir.actions.act_window">
        <field name="name">Leave Balance Summary</field>
        <field name="res_model">hr.leave.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'validate')]</field>
    </record>

    <!-- Checklist actions -->
    <record id="action_hr_onboarding_checklist" model="ir.actions.act_window">
        <field name="name">Onboarding Checklists</field>
        <field name="res_model">hr.onboarding.checklist.item</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('checklist_type', '=', 'onboarding'), ('done', '=', False)]</field>
    </record>

    <!-- HR Announcements -->
    <record id="action_hr_announcement" model="ir.actions.act_window">
        <field name="name">HR Announcements</field>
        <field name="res_model">hr.announcement</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
