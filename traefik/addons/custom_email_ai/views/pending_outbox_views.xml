<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_email_ai_outbox_list" model="ir.ui.view">
        <field name="name">email.ai.outbox.list</field>
        <field name="model">email.ai.outbox</field>
        <field name="arch" type="xml">
            <list string="Pending Outbox"
                  decoration-primary="state == 'pending'"
                  decoration-success="state == 'approved'"
                  decoration-muted="state in ('sent','rejected')">
                <field name="subject"/>
                <field name="to_email"/>
                <field name="create_date" string="Created"/>
                <field name="ai_draft" string="AI Draft"/>
                <field name="state" widget="badge"/>
                <field name="approved_by_id" optional="show"/>
                <button name="action_approve" string="Approve" type="object"
                        class="btn-sm btn-success" invisible="state != 'pending'"/>
                <button name="action_send" string="Send" type="object"
                        class="btn-sm btn-primary" invisible="state != 'approved'"/>
            </list>
        </field>
    </record>

    <record id="view_email_ai_outbox_form" model="ir.ui.view">
        <field name="name">email.ai.outbox.form</field>
        <field name="model">email.ai.outbox</field>
        <field name="arch" type="xml">
            <form string="Pending Email">
                <header>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success" invisible="state != 'pending'"/>
                    <button name="action_reject" string="Reject" type="object"
                            class="btn-danger" invisible="state != 'pending'"/>
                    <button name="action_needs_info" string="Needs More Info" type="object"
                            class="btn-warning" invisible="state != 'pending'"/>
                    <button name="action_send" string="Send Email" type="object"
                            class="btn-primary" invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,approved,sent"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        ⚠️ <strong>AI-drafted emails are NEVER auto-sent.</strong>
                        Review and approve before sending.
                    </div>
                    <group>
                        <group>
                            <field name="subject"/>
                            <field name="to_email"/>
                            <field name="cc_email"/>
                            <field name="mailbox_id"/>
                            <field name="template_id" readonly="1"/>
                            <field name="ai_draft" readonly="1"/>
                        </group>
                        <group>
                            <field name="state" readonly="1"/>
                            <field name="approved_by_id" readonly="1"/>
                            <field name="sent_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="AI Draft (read-only)">
                        <field name="body_draft" nolabel="1" readonly="1" widget="text"/>
                    </group>
                    <group string="Final Body (edit before approving)">
                        <field name="body_final" nolabel="1" widget="text"/>
                    </group>
                    <group string="Reason for Edit (if modified)">
                        <field name="edit_reason" nolabel="1" widget="text"
                               placeholder="Why was the AI draft changed? Stored for AI improvement."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_email_ai_outbox" model="ir.actions.act_window">
        <field name="name">Pending Outbox</field>
        <field name="res_model">email.ai.outbox</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','not in',('sent',))]</field>
    </record>

</odoo>
