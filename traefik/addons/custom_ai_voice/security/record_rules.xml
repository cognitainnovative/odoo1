<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_voice_call_company" model="ir.rule">
        <field name="name">Voice Call: company scope</field>
        <field name="model_id" ref="model_voice_call"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_voice_call_flow_company" model="ir.rule">
        <field name="name">Voice Call Flow: company scope</field>
        <field name="model_id" ref="model_voice_call_flow"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_voice_provider_company" model="ir.rule">
        <field name="name">Voice Provider: company scope</field>
        <field name="model_id" ref="model_voice_provider"/>
        <field name="domain_force">[('company_id','in',company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
