<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ stock.audit.log — list + form ═══ -->
    <record id="view_stock_audit_log_list" model="ir.ui.view">
        <field name="name">stock.audit.log.list</field>
        <field name="model">stock.audit.log</field>
        <field name="arch" type="xml">
            <list string="Stock Audit Log" create="0" edit="0" delete="0">
                <field name="create_date" string="Timestamp"/>
                <field name="event_type"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="quantity"/>
                <field name="location_from_id"/>
                <field name="location_to_id"/>
                <field name="origin_ref"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_stock_audit_log_form" model="ir.ui.view">
        <field name="name">stock.audit.log.form</field>
        <field name="model">stock.audit.log</field>
        <field name="arch" type="xml">
            <form string="Stock Audit Log Entry" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="event_type"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="quantity"/>
                        </group>
                        <group>
                            <field name="location_from_id"/>
                            <field name="location_to_id"/>
                            <field name="origin_ref"/>
                            <field name="user_id"/>
                            <field name="create_date" string="Timestamp"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stock_audit_log" model="ir.actions.act_window">
        <field name="name">Stock Audit Log</field>
        <field name="res_model">stock.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"create": False}</field>
    </record>

</odoo>
