<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Dashboard quick-access actions ── -->

    <record id="action_low_stock_products" model="ir.actions.act_window">
        <field name="name">Low Stock Products</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_storable','=',True),('qty_available','&lt;=',0)]</field>
        <field name="context">{"search_default_filter_to_reorder": 1}</field>
    </record>

    <record id="action_out_of_stock_products" model="ir.actions.act_window">
        <field name="name">Out of Stock</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_storable','=',True),('qty_available','&lt;=',0)]</field>
    </record>

    <record id="action_fast_movers" model="ir.actions.act_window">
        <field name="name">Fast Movers</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('fast_mover','=',True),('is_storable','=',True)]</field>
    </record>

    <record id="action_reorder_rules" model="ir.actions.act_window">
        <field name="name">Reorder Rules</field>
        <field name="res_model">stock.warehouse.orderpoint</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_stock_moves_today" model="ir.actions.act_window">
        <field name="name">Today's Stock Moves</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','done'),('date','&gt;=',context_today())]</field>
    </record>

    <!-- Stock value: storable products ordered by total value descending -->
    <record id="action_stock_value" model="ir.actions.act_window">
        <field name="name">Stock Value</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_storable','=',True)]</field>
        <field name="context">{"search_default_filter_to_reorder": 0, "orderby": "value_svl desc"}</field>
    </record>

    <!-- Reserved stock: storable products that have outgoing reservations -->
    <record id="action_reserved_stock" model="ir.actions.act_window">
        <field name="name">Reserved Stock</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_storable','=',True),('outgoing_qty','&gt;',0)]</field>
    </record>

    <!-- Warehouse overview -->
    <record id="action_warehouse_overview" model="ir.actions.act_window">
        <field name="name">Warehouse Overview</field>
        <field name="res_model">stock.warehouse</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>

</odoo>
