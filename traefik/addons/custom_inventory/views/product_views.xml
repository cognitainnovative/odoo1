<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ product.template — Platform Inventory tab + Documents button ═══ -->
    <record id="view_product_template_platform" model="ir.ui.view">
        <field name="name">product.template.platform.inventory</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <!-- Documents smart button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_documents" type="object"
                        class="oe_stat_button" icon="fa-file-text-o"
                        invisible="document_count == 0">
                    <field name="document_count" widget="statinfo" string="Docs"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Platform Inventory" name="platform_inventory">
                    <group>
                        <group>
                            <field name="platform_sku" placeholder="e.g. SKU-00123"/>
                            <field name="fast_mover"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ═══ product.bundle — list + form ═══ -->
    <record id="view_product_bundle_list" model="ir.ui.view">
        <field name="name">product.bundle.list</field>
        <field name="model">product.bundle</field>
        <field name="arch" type="xml">
            <list string="Product Bundles" decoration-muted="not active">
                <field name="name"/>
                <field name="product_id"/>
                <field name="component_count" string="Components"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_product_bundle_form" model="ir.ui.view">
        <field name="name">product.bundle.form</field>
        <field name="model">product.bundle</field>
        <field name="arch" type="xml">
            <form string="Product Bundle">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="bundle_line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id" readonly="1"/>
                            <field name="qty_available" string="On Hand" readonly="1"/>
                        </list>
                    </field>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_product_bundle" model="ir.actions.act_window">
        <field name="name">Product Bundles</field>
        <field name="res_model">product.bundle</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
