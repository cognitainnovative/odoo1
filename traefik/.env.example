# ── Docker Compose overrides ──────────────────────────────────────────────────
# These are read by docker-compose.yml. For local dev (make up) they are unused.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
ODOO_ADMIN_USER=admin
OCR_PROVIDER=mock            # mock | mindee | azure

# ── Odoo / DB ──────────────────────────────────────────────────────────────────
ODOO_ADMIN_PASSWORD=dev_admin_change_in_prod
POSTGRES_DB=platform_dev
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

# ── Redis / Cache (optional for dev; required for Celery/chat) ─────────────────
REDIS_URL=redis://localhost:6379/0

# ── Object storage (MinIO / S3-compatible) ─────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=platform-docs

# ── AI providers (all optional; mock provider used when absent) ────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OLLAMA_BASE_URL=http://localhost:11434
AI_DEFAULT_DRAFTING_PROVIDER=anthropic
AI_DEFAULT_CLASSIFY_PROVIDER=openai
AI_ALLOW_EXTERNAL=false
AI_PRIVACY_REDACTION=true

# ── AI Gateway service (services/ai_gateway) ──────────────────────────────────
AI_GATEWAY_SECRET=
AI_DEFAULT_PROVIDER=mock                  # mock | anthropic | openai | ollama | azure
AI_DEFAULT_MODEL=                         # leave empty to use provider default
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=nomic-embed-text
REDACT_PII_EXTERNAL=true                  # strip PII before external provider calls

# ── Integration Gateway service (services/integration_gateway) ────────────────
WHATSAPP_APP_SECRET=                      # Meta App Secret for X-Hub-Signature-256 verify
BANK_IMPORT_SECRET=                       # Shared secret for /webhooks/bank/import
ODOO_ADMIN_USER=admin
ODOO_ADMIN_PASSWORD=admin                 # Only used by integration-gateway → Odoo RPC

# ── OCR (optional) ────────────────────────────────────────────────────────────
MINDEE_API_KEY=
AZURE_DOCAI_ENDPOINT=
AZURE_DOCAI_KEY=

# ── Telephony / SMS / Voice (optional) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
SIP_WEBHOOK_SECRET=

# ── WhatsApp (optional; needs Meta app review for Cloud API) ───────────────────
WHATSAPP_PROVIDER=meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Email (optional; IMAP/SMTP always works without these) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── Social (optional; needs app review per platform) ──────────────────────────
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=

# ── Bank (optional; file import works without keys) ───────────────────────────
GOCARDLESS_BANKDATA_SECRET_ID=
GOCARDLESS_BANKDATA_SECRET_KEY=

# ── Payments (optional) ───────────────────────────────────────────────────────
MOLLIE_API_KEY=
STRIPE_API_KEY=

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ── Security ──────────────────────────────────────────────────────────────────
APP_SECRET_ENCRYPTION_KEY=          # Fernet key for stored provider keys
INTERNAL_SERVICE_TOKEN=             # Odoo <-> FastAPI auth token
